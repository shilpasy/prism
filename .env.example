# ── Local development ────────────────────────────────────────────────────────
# Copy this file to .env and fill in your key. .env is gitignored.
OPENAI_API_KEY=sk-proj-your-key-here

# Lets local runs use OPENAI_API_KEY above without pasting it into the UI.
# NEVER set this on Railway or any server — it keeps a stray key inert in
# production, so the only server-funded (spend-capped) key is PRISM_FREE_KEY.
PRISM_ALLOW_ENV_KEY=1

# ── Server / free tier (set these in the Railway dashboard, NOT here) ──────────
# PRISM_FREE_KEY=sk-proj-...        # owner-funded key for the free trial (capped)
# PRISM_DAILY_FREE_LIMIT=10         # global hard cap across all users (~$1/day)
# PRISM_FREE_PER_SESSION=2          # free runs per visitor before own key needed
